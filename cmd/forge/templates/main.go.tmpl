package main

import (
	"fmt"
	"os"

	"github.com/andrewhowdencom/ore/app"
{{- if or .Handlers .Transforms }}
	"github.com/andrewhowdencom/ore/loop"
{{- end }}
	"github.com/andrewhowdencom/ore/session"
	"github.com/andrewhowdencom/ore/x/conduit"
{{- range .Conduits }}
	{{.ImportAlias}} "{{.ModulePath}}"
{{- end }}
{{- range .Handlers }}
	{{.ImportAlias}} "{{.ModulePath}}"
{{- end }}
{{- range .Transforms }}
	{{.ImportAlias}} "{{.ModulePath}}"
{{- end }}
)

func main() {
	if err := app.Run(
		app.WithName("{{.Name}}"),
{{- range .Conduits }}
{{- if .HasOptions }}
		app.WithConduit("{{.Name}}", func(mgr *session.Manager, opts map[string]any) (conduit.Conduit, error) {
			{{.ImportAlias}}Opts, err := {{.ImportAlias}}.OptionsFromMap(opts)
			if err != nil {
				return nil, err
			}
			return {{.ImportAlias}}.New(mgr, {{.ImportAlias}}Opts...)
		}, {{.OptionsLiteral}}),
{{- else }}
		app.WithConduit("{{.Name}}", func(mgr *session.Manager, opts map[string]any) (conduit.Conduit, error) {
			return {{.ImportAlias}}.New(mgr)
		}, nil),
{{- end }}
{{- end }}
{{- range .Handlers }}
{{- if .HasOptions }}
		app.WithHandler("{{.Name}}", func(opts map[string]any) (loop.Handler, error) {
			{{.ImportAlias}}Opts, err := {{.ImportAlias}}.OptionsFromMap(opts)
			if err != nil {
				return nil, err
			}
			return {{.ImportAlias}}.New({{.ImportAlias}}Opts...)
		}, {{.OptionsLiteral}}),
{{- else }}
		app.WithHandler("{{.Name}}", func(opts map[string]any) (loop.Handler, error) {
			return {{.ImportAlias}}.New()
		}, nil),
{{- end }}
{{- end }}
{{- range .Transforms }}
{{- if .HasOptions }}
		app.WithTransform("{{.Name}}", func(opts map[string]any) (loop.Transform, error) {
			{{.ImportAlias}}Opts, err := {{.ImportAlias}}.OptionsFromMap(opts)
			if err != nil {
				return nil, err
			}
			tr, err := {{.ImportAlias}}.New({{.ImportAlias}}Opts...)
			if err != nil {
				return nil, err
			}
			return tr.AsTransform(), nil
		}, {{.OptionsLiteral}}),
{{- else }}
		app.WithTransform("{{.Name}}", func(opts map[string]any) (loop.Transform, error) {
			tr, err := {{.ImportAlias}}.New()
			if err != nil {
				return nil, err
			}
			return tr.AsTransform(), nil
		}, nil),
{{- end }}
{{- end }}
	); err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
}
